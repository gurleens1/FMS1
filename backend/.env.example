# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://fms_user:fms_password@localhost:5432/fms_db?schema=public"

# ─────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────
# AZURE AD / MSAL (Microsoft Entra ID)
# ─────────────────────────────────────────────
# These must match your Azure App Registration
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-backend-client-id-here
AZURE_CLIENT_SECRET=your-backend-client-secret-here

# The audience for JWT validation (matches frontend app registration)
AZURE_AUDIENCE=api://your-backend-client-id-here

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ─────────────────────────────────────────────
# AWS (for production)
# ─────────────────────────────────────────────
AWS_REGION=ap-south-1
S3_BUCKET_NAME=fms-recordings-bucket

# ─────────────────────────────────────────────
# AI INSIGHTS (future integration)
# ─────────────────────────────────────────────
# ANTHROPIC_API_KEY=your-key-here
# OPENAI_API_KEY=your-key-here
AI_INSIGHTS_ENABLED=false
